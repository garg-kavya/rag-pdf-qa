# =============================================================================
# Environment Variables — RAG PDF Q&A
# =============================================================================
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Database (PostgreSQL) ---
# Local dev: postgresql://docmind:docmind@localhost:5432/docmind
# Railway/Render: paste the DATABASE_URL from your PostgreSQL service
DATABASE_URL=postgresql://docmind:docmind@localhost:5432/docmind

# --- Application ---
APP_NAME=DocMind
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# --- OpenAI Models ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- Chunking ---
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# --- Auth ---
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Retrieval ---
VECTOR_STORE_TYPE=chroma
TOP_K=5
TOP_K_CANDIDATES=10
SIMILARITY_THRESHOLD=0.0
MMR_DIVERSITY_FACTOR=0.3

# --- Observability: LangSmith (optional) ---
# Sign up free at smith.langchain.com → Settings → API Keys
# Traces every LLM call (completions + embeddings), full prompt/response,
# token counts, cost, and latency grouped by pipeline run.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-key-here
# LANGCHAIN_PROJECT=DocMind

# --- Reranker (optional) ---
# Set RERANKER_BACKEND to "cross_encoder" or "cohere" to enable.
# Default "none" uses MMR-only ordering (no cross-encoder).
RERANKER_BACKEND=none
# COHERE_API_KEY=your-cohere-key-here     # required if RERANKER_BACKEND=cohere
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Cache ---
CACHE_BACKEND=memory
CACHE_MAX_SIZE=1000
EMBEDDING_CACHE_TTL_SECONDS=86400
RESPONSE_CACHE_TTL_SECONDS=60

# --- Memory ---
MEMORY_TOKEN_BUDGET=1024
COMPRESSION_THRESHOLD=10
COMPRESSION_TURNS=5

# --- Sessions ---
SESSION_TTL_MINUTES=60
MAX_CONVERSATION_TURNS=10
SESSION_CLEANUP_INTERVAL_SECONDS=300

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
CORS_ORIGINS=*

# --- Storage Paths ---
UPLOAD_DIR=./uploads
VECTOR_STORE_PATH=./data
