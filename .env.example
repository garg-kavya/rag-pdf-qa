# =============================================================================
# Environment Variables — RAG PDF Q&A
# =============================================================================
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---
OPENAI_API_KEY=sk-your-api-key-here

# --- Application ---
APP_NAME=RAG PDF Q&A
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# --- OpenAI Models ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- Chunking ---
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# --- Retrieval ---
VECTOR_STORE_TYPE=faiss
TOP_K=5
TOP_K_CANDIDATES=10
SIMILARITY_THRESHOLD=0.70
MMR_DIVERSITY_FACTOR=0.3

# --- Reranker (optional) ---
# Set RERANKER_BACKEND to "cross_encoder" or "cohere" to enable.
# Default "none" uses MMR-only ordering (no cross-encoder).
RERANKER_BACKEND=none
# COHERE_API_KEY=your-cohere-key-here     # required if RERANKER_BACKEND=cohere
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Cache ---
CACHE_BACKEND=memory
CACHE_MAX_SIZE=1000
EMBEDDING_CACHE_TTL_SECONDS=86400
RESPONSE_CACHE_TTL_SECONDS=60

# --- Memory ---
MEMORY_TOKEN_BUDGET=1024
COMPRESSION_THRESHOLD=10
COMPRESSION_TURNS=5

# --- Sessions ---
SESSION_TTL_MINUTES=60
MAX_CONVERSATION_TURNS=10
SESSION_CLEANUP_INTERVAL_SECONDS=300

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
CORS_ORIGINS=*

# --- Storage Paths ---
UPLOAD_DIR=./uploads
VECTOR_STORE_PATH=./data
